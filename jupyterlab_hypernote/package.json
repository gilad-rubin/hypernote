{
  "name": "jupyterlab-hypernote",
  "version": "0.1.0",
  "description": "JupyterLab extension for Hypernote status projection",
  "keywords": ["jupyter", "jupyterlab", "jupyterlab-extension"],
  "license": "MIT",
  "author": "Hypernote",
  "files": ["lib/**/*.{d.ts,js,json}", "style/**/*.css"],
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "jupyterlab": {
    "extension": true,
    "outputDir": "hypernote/labextension"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rimraf lib tsconfig.tsbuildinfo",
    "watch": "tsc -w"
  },
  "dependencies": {
    "@jupyterlab/application": "^4.0.0",
    "@jupyterlab/apputils": "^4.0.0",
    "@jupyterlab/notebook": "^4.0.0",
    "@jupyterlab/services": "^7.0.0",
    "@jupyterlab/ui-components": "^4.0.0",
    "@lumino/widgets": "^2.0.0",
    "@lumino/signaling": "^2.0.0",
    "@lumino/polling": "^2.0.0"
  },
  "devDependencies": {
    "typescript": "~5.3.0",
    "rimraf": "^5.0.0"
  }
}
